# Optional AI drafting. Copy this file to .env and add a key if you want
# reviewable AI drafts for Status Summary and Teams Draft.
# Do not commit .env or share real keys.

# AI_PROVIDER=openai
# OPENAI_API_KEY=replace_with_your_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_MAX_TOKENS=2000
# Optional: provider requests stop after 45 seconds by default (1–120 seconds allowed).
# AI_REQUEST_TIMEOUT_MS=45000

# AI_PROVIDER=claude
# CLAUDE_API_KEY=replace_with_your_key
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MAX_TOKENS=2000
# CLAUDE_API_URL is intentionally not configurable to a custom host: keys are only sent
# to https://api.anthropic.com/v1/messages.
